# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
NEXT_PUBLIC_GA_MEASUREMENT_ID=
GA_MEASUREMENT_PROTOCOL_API_SECRET=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs — set these once prices are created in the Stripe dashboard.
# Used by the webhook service layer to map subscriptions to membership tiers.
STRIPE_PRICE_LEVEL_1_MONTHLY=
STRIPE_PRICE_LEVEL_2_MONTHLY=
STRIPE_PRICE_LEVEL_3_MONTHLY=
STRIPE_PRICE_LEVEL_4_MONTHLY=
STRIPE_PRICE_LEVEL_1_ANNUAL=
STRIPE_PRICE_LEVEL_2_ANNUAL=
STRIPE_PRICE_LEVEL_3_ANNUAL=
STRIPE_PRICE_LEVEL_4_ANNUAL=

# Stripe product ID (L4 custom package presets)
STRIPE_PRODUCT_LEVEL_4=

# Resend (transactional email)
RESEND_API_KEY=
SEND_EMAIL_HOOK_SECRET=
EMAIL_UNSUBSCRIBE_SECRET=

# Vercel Cron — protects /api/cron/* endpoints
CRON_SECRET=

# Billing recovery — HMAC-SHA256 secret for signed 1-click billing portal tokens
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BILLING_TOKEN_SECRET=

# FirstPromoter (affiliate tracking + promoter management)
FIRSTPROMOTER_API_KEY=
FIRSTPROMOTER_ACCOUNT_ID=
FIRSTPROMOTER_CAMPAIGN_ID=

# Vimeo
VIMEO_ACCESS_TOKEN=
VIMEO_CLIENT_ID=
VIMEO_CLIENT_SECRET=

# AWS / S3
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=

# Google Drive ingestion
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_DRIVE_DAILY_AUDIO_FOLDER_ID=

# Castos
CASTOS_API_KEY=
CASTOS_SHOW_ID=

# ActiveCampaign
ACTIVECAMPAIGN_API_URL=
ACTIVECAMPAIGN_API_KEY=

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Optional AI metadata generation
OPENAI_API_KEY=

# Mux (video)
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=

# Admin access bootstrap
ADMIN_EMAILS=
